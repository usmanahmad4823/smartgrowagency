# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: file:./dev.db (SQLite)
# Production: postgresql://USER:PASSWORD@HOST:PORT/DATABASE (Postgres required on Vercel)
DATABASE_URL="file:./dev.db"

# ─── Site ────────────────────────────────────────────────────────────────────
# Full URL with no trailing slash. Update to your production domain on Vercel.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Optional — leads are saved to the DB regardless. Omit to disable email notifications.
AGENCY_INBOX_EMAIL="you@yourdomain.com"
EMAIL_FROM="Creecode Studio <you@yourdomain.com>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"

# ─── Live chat (Tawk.to) ─────────────────────────────────────────────────────
# Leave blank to disable the chat widget.
NEXT_PUBLIC_TAWK_PROPERTY_ID=""
NEXT_PUBLIC_TAWK_WIDGET_ID=""
